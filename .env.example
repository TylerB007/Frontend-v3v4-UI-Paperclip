# Copy to .env.local and fill in values

# Fee recipient wallet (20bps interface fee via PAY_PORTION in Universal Router)
NEXT_PUBLIC_FEE_RECIPIENT=0xec85f997f75f85f3e598d4c769fe0233f3dae2d4

# Comma-separated supported chain IDs (1=Ethereum mainnet, 8453=Base)
NEXT_PUBLIC_SUPPORTED_CHAINS=1,8453

# WalletConnect project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Uniswap V4 subgraph endpoints (The Graph decentralized network)
# Format: https://gateway.thegraph.com/api/{API_KEY}/subgraphs/id/{SUBGRAPH_ID}
# Known subgraph IDs:
#   Mainnet: DiYPVdygkfjDWhbxGSqAQxwBKmfKnkWQojqeM3nMiqki
#   Base:    GqzP4Xaehti8KSfQmv3ZctFSjnSUYZ4En5NRsiTbvZpz
# If not set, position enumeration falls back to Viem getLogs (slower, works without API key).
NEXT_PUBLIC_SUBGRAPH_URL_MAINNET=
NEXT_PUBLIC_SUBGRAPH_URL_BASE=
# Dev/testing chains (optional):
NEXT_PUBLIC_SUBGRAPH_URL_SEPOLIA=
NEXT_PUBLIC_SUBGRAPH_URL_BASE_SEPOLIA=
